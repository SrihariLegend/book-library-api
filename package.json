{
  "name": "practices-demo",
  "version": "1.0.0",
  "description": "Book Library API demonstrating: Repository Pattern, Immutability, Validation, TDD, Security",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "dependencies": {
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "express-rate-limit": "8.3.1",
    "helmet": "8.1.0",
    "uuid": "13.0.0",
    "winston": "3.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.5.0",
    "@types/supertest": "7.2.0",
    "@types/uuid": "11.0.0",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "eslint": "9.23.0",
    "jest": "30.3.0",
    "prettier": "3.8.1",
    "supertest": "7.2.2",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
